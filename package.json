{
  "name": "@obscuraworks/libsignal-node",
  "version": "1.3.0",
  "description": "Node.js implementation of the Signal Protocol cryptographic primitives used by ObscuraWorks services.",
  "keywords": [
    "signal",
    "libsignal",
    "curve25519",
    "cryptography",
    "e2ee",
    "end-to-end-encryption",
    "obscuraworks"
  ],
  "author": {
    "name": "ObscuraWorks",
    "url": "https://github.com/obscuraworks"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/obscuraworks/libsignal-node.git"
  },
  "bugs": {
    "url": "https://github.com/obscuraworks/libsignal-node/issues"
  },
  "homepage": "https://github.com/obscuraworks/libsignal-node#readme",
  "type": "commonjs",
  "main": "./index.js",

  "exports": {
    ".": "./index.js",
    "./crypto": "./src/crypto.js",
    "./curve": "./src/curve.js",
    "./keyhelper": "./src/keyhelper.js",
    "./protocol_address": "./src/protocol_address.js",
    "./session_builder": "./src/session_builder.js",
    "./session_cipher": "./src/session_cipher.js",
    "./session_record": "./src/session_record.js",
    "./errors": "./src/errors.js"
  },

  "files": [
    "index.js",
    "src"
  ],

  "engines": {
    "node": ">=20.0.0"
  },

  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },

  "dependencies": {
    "curve25519-js": "^0.0.4",
    "protobufjs": "6.8.8"
  },

  "devDependencies": {
    "eslint": "6.0.1"
  }
}
